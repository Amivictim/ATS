            for _,stat in ipairs(STATS) do
                if statToggles[stat] then
                    if not isGoodEnough(getGrade(stat), statTargets[stat]) then
                        Remote:FireServer(selectedUnit,"Reroll",stat)
                        task.wait(0.2)
                    end
                end
            end
            rolls=rolls+1
            -- Status güncelle: mevcut grade'leri göster
            local parts={}
            for _,stat in ipairs(STATS) do
                if statToggles[stat] then
                    local g=getGrade(stat) or "?"
                    table.insert(parts, STAT_DISPLAY[stat]:match("[%a%s]+$"):gsub("^%s+","")..": "..g)
                end
            end
            StLbl.Text="🔄 #"..rolls.." | "..table.concat(parts," | ")
            task.wait(0.4)
        end
    end)
