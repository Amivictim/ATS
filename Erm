        and PlayerGui.Units._Frame:FindFirstChild("Usage")
        and PlayerGui.Units._Frame.Usage:FindFirstChild("BODY")
        and PlayerGui.Units._Frame.Usage.BODY:FindFirstChild("Useable")
        and PlayerGui.Units._Frame.Usage.BODY.Useable:FindFirstChild("Interview")
    local units={}
    if iv then
        for _,c in ipairs(iv:GetChildren()) do
            if not c:IsA("UIGridLayout") and not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
                table.insert(units,c.Name)
            end
        end
        table.sort(units)
    end
    if #units==0 then
        local nb=Instance.new("TextButton",UList)
        nb.Size=UDim2.new(1,0,0,30); nb.BackgroundTransparency=1
        nb.Text="⚠ Units GUI açık değil!"; nb.TextColor3=Color3.fromRGB(255,80,80)
        nb.TextSize=11; nb.Font=Enum.Font.Gotham
