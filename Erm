-- ===================== GRADES =====================
local GRADES = {
    "SSS+", "SSS", "SSS-",
    "SS+",  "SS",  "SS-",
    "S+",   "S",   "S-",
    "A+",   "A",   "A-",
    "B+",   "B",   "B-",
    "C+",   "C",   "C-",
    "D+",   "D",   "D-",
    "E+",   "E",   "E-",
}

local GRADE_RANK = {}
for i, g in ipairs(GRADES) do GRADE_RANK[g] = i end

local function gradeFromText(text)
    text = text:gsub("%s+", "")
    for _, g in ipairs(GRADES) do
        if text == g then return g end
    end
    for _, g in ipairs(GRADES) do
        if text:find(g, 1, true) then return g end
    end
    return nil
end

local function isGoodEnough(cur, target)
    if not cur or not target then return false end
    local cr, tr = GRADE_RANK[cur], GRADE_RANK[target]
    if not cr or not tr then return false end
    return cr <= tr -- lower index = better grade
end

