        isRunning=false
        SBtn.Text="▶   Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(78,42,195)
        StLbl.Text="⏸  Durduruldu"; StLbl.TextColor3=Color3.fromRGB(220,95,95)
        return
    end
    if not selectedUnit then
        StLbl.Text="⚠  Önce ünite seçin!"; StLbl.TextColor3=Color3.fromRGB(255,195,50); return
    end
    local any=false
    for _,v in pairs(statToggles) do if v then any=true break end end
    if not any then
        StLbl.Text="⚠  En az 1 stat açın!"; StLbl.TextColor3=Color3.fromRGB(255,195,50); return
    end

    isRunning=true
    SBtn.Text="⏹   Durdur"; SBtn.BackgroundColor3=Color3.fromRGB(175,38,38)
    StLbl.Text="🔄  Başlatılıyor..."; StLbl.TextColor3=Color3.fromRGB(130,255,155)

    task.spawn(function()
        local rolls=0
        while isRunning do
            if not needsReroll() then
                isRunning=false
                SBtn.Text="▶   Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(78,42,195)
                StLbl.Text="✅ Tamamlandı! ("..rolls.." roll)"; StLbl.TextColor3=Color3.fromRGB(95,255,155)
