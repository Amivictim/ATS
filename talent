local currentPopupStat=nil
local gradeButtons={} -- grade -> button ref, per stat
local statGradeBtns={} -- stat -> summary button ref

local function buildGradePopup(stat, anchorBtn)
    currentPopupStat=stat
    -- Clear
    for _,c in ipairs(GradeScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end

    for gi,grade in ipairs(GRADES) do
        local selected=statAccepted[stat][grade]==true
        local gb=Instance.new("TextButton",GradeScroll)
        gb.Size=UDim2.new(1,0,0,26); gb.BorderSizePixel=0; gb.LayoutOrder=gi
        gb.BackgroundColor3=selected and Color3.fromRGB(58,34,118) or Color3.fromRGB(24,20,40)
        gb.BackgroundTransparency=selected and 0 or 0.3
        gb.Text=(selected and "✔ " or "  ")..grade
        gb.TextColor3=gradeColors[grade] or Color3.fromRGB(220,220,220)
        gb.TextSize=12; gb.Font=Enum.Font.GothamBold; gb.ZIndex=11

        gb.MouseButton1Click:Connect(function()
            statAccepted[stat][grade]=not statAccepted[stat][grade]
            local sel=statAccepted[stat][grade]
            gb.BackgroundColor3=sel and Color3.fromRGB(58,34,118) or Color3.fromRGB(24,20,40)
            gb.BackgroundTransparency=sel and 0 or 0.3
            gb.Text=(sel and "✔ " or "  ")..grade

            -- Update summary button text
            local picks={}
            for _,g in ipairs(GRADES) do if statAccepted[stat][g] then table.insert(picks,g) end end
            local ref=statGradeBtns[stat]
            if ref then
                if #picks==0 then
                    ref.Text="Seç ▾"; ref.TextColor3=Color3.fromRGB(160,155,200)
                elseif #picks==1 then
                    ref.Text=picks[1].." ▾"; ref.TextColor3=gradeColors[picks[1]] or Color3.fromRGB(220,220,220)
                else
                    ref.Text=picks[1].."+"..tostring(#picks-1).." ▾"
                    ref.TextColor3=Color3.fromRGB(200,180,255)
                end
            end
        end)
    end

    GradeScroll.CanvasSize=UDim2.new(0,0,0,#GRADES*26)

    -- Position popup near button
    local abs=anchorBtn.AbsolutePosition
    local sz=anchorBtn.AbsoluteSize
    local popH=math.min(#GRADES*26+4,180)
    GradePopup.Size=UDim2.new(0,150,0,popH)
    -- Try below, if off-screen go above
    local screenH=SG.AbsoluteSize.Y
    local topBelow=abs.Y+sz.Y+4
    if topBelow+popH>screenH then
        GradePopup.Position=UDim2.new(0,abs.X+sz.X-150,0,abs.Y-popH-4)
    else
        GradePopup.Position=UDim2.new(0,abs.X+sz.X-150,0,topBelow)
    end
    GradePopup.Visible=true
end

