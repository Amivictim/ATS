local GRADES = {"SSS+","SSS","SSS-","SS+","SS","SS-","S+","S","S-",
                "A+","A","A-","B+","B","B-","C+","C","C-","D+","D","D-","E+","E","E-"}

local function gradeFromText(t)
    t=t:gsub("%s+","")
    for _,g in ipairs(GRADES) do if t==g then return g end end
    for _,g in ipairs(GRADES) do if t:find(g,1,true) then return g end end
end

