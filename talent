    end
    local anyE=false
    for _,v in pairs(statToggles) do if v then anyE=true break end end
    if not anyE then
        StLbl.Text="⚠  En az 1 stat açın!"; StLbl.TextColor3=Color3.fromRGB(255,190,45); return
    end
    -- Check grade selections
    for _,stat in ipairs(STATS) do
        if statToggles[stat] then
            local any=false
            for _,v in pairs(statAccepted[stat]) do if v then any=true break end end
            if not any then
                StLbl.Text="⚠  "..STAT_LABEL[stat].." için grade seç!"; StLbl.TextColor3=Color3.fromRGB(255,190,45); return
            end
        end
    end

    isRunning=true
    SBtn.Text="⏹   Durdur"; SBtn.BackgroundColor3=Color3.fromRGB(170,36,36)
    StLbl.Text="🔄  Başlatılıyor..."; StLbl.TextColor3=Color3.fromRGB(120,255,150)

    task.spawn(function()
        local rolls=0
        while isRunning do
            if not needsReroll() then
                isRunning=false
                SBtn.Text="▶   Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(75,40,190)
                StLbl.Text="✅ Tamamlandı! ("..rolls.." roll)"; StLbl.TextColor3=Color3.fromRGB(90,255,150)
                break
            end
            for _,stat in ipairs(STATS) do
                if statToggles[stat] and not isAccepted(stat) then
                    Remote:FireServer(selectedUnit,"Reroll",stat)
                    task.wait(0.2)
                end
            end
            rolls=rolls+1
            local parts={}
            for _,stat in ipairs(STATS) do
                if statToggles[stat] then
                    local g=getGrade(stat) or "?"
                    table.insert(parts,STAT_LABEL[stat]..":"..g)
                end
            end
            StLbl.Text="🔄 #"..rolls.." | "..table.concat(parts," ")
            task.wait(0.35)
        end
    end)
end)
