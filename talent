local function populateUnits()
    for _,c in ipairs(UList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    local iv = PGui:FindFirstChild("Units")
        and PGui.Units:FindFirstChild("_Frame")
        and PGui.Units._Frame:FindFirstChild("Usage")
        and PGui.Units._Frame.Usage:FindFirstChild("BODY")
        and PGui.Units._Frame.Usage.BODY:FindFirstChild("Useable")
        and PGui.Units._Frame.Usage.BODY.Useable:FindFirstChild("Interview")
    local units={}
    if iv then
        for _,c in ipairs(iv:GetChildren()) do
            if not c:IsA("UIGridLayout") and not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
                table.insert(units,c.Name)
            end
        end
        table.sort(units)
    end
    if #units==0 then
        local nb=Instance.new("TextButton",UList)
        nb.Size=UDim2.new(1,0,0,28); nb.BackgroundTransparency=1
        nb.Text="⚠ Units GUI açık değil!"; nb.TextColor3=Color3.fromRGB(255,75,75)
        nb.TextSize=10; nb.Font=Enum.Font.Gotham
        UList.CanvasSize=UDim2.new(0,0,0,28); return
    end
    for i,uid in ipairs(units) do
        local dn=(uid:match("^(.-)%s*%-") or uid):gsub("^%s+",""):gsub("%s+$","")
        local b=Instance.new("TextButton",UList)
        b.Size=UDim2.new(1,0,0,28)
        b.BackgroundColor3=selectedUnit==uid and Color3.fromRGB(62,35,140) or Color3.fromRGB(26,22,44)
        b.BackgroundTransparency=selectedUnit==uid and 0 or 0.2
        b.Text="  "..dn; b.TextColor3=Color3.fromRGB(210,205,250)
        b.TextSize=11; b.Font=Enum.Font.Gotham
        b.TextXAlignment=Enum.TextXAlignment.Left; b.BorderSizePixel=0; b.LayoutOrder=i
        b.MouseButton1Click:Connect(function()
            selectedUnit=uid
            UBtn.Text="  ✔ "..dn.." ▾"; UBtn.TextColor3=Color3.fromRGB(120,255,150)
            unitOpen=false; UList.Visible=false; UList.Size=UDim2.new(1,0,0,0)
        end)
    end
    UList.CanvasSize=UDim2.new(0,0,0,#units*28)
end

