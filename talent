-- ── COUNTDOWN HELPER ─────────────────────────────────────────────────────────
local function waitWithCountdown(seconds, labelPrefix)
    for t = seconds, 1, -1 do
        if not isRunning then return end
        StLbl.Text = labelPrefix .. " (" .. t .. "s)"
        task.wait(1)
    end
end

-- ── LOGIC ─────────────────────────────────────────────────────────────────────
local function isAccepted(stat)
    local anyGrade=false
    for _,v in pairs(statAccepted[stat]) do if v then anyGrade=true; break end end
    if not anyGrade then return false end
    local cur=getGrade(stat); if not cur then return false end
    return statAccepted[stat][cur]==true
end

SBtn.MouseButton1Click:Connect(function()
    if isRunning then
        isRunning=false
        SBtn.Text="▶  Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(72,38,188)
        StLbl.Text="⏸ Durduruldu"; StLbl.TextColor3=Color3.fromRGB(210,85,85)
        return
    end
    if not selectedUnit then
        StLbl.Text="⚠ Ünite seç!"; StLbl.TextColor3=Color3.fromRGB(255,185,40); return end
    local anyEnabled=false
    for _,stat in ipairs(STATS) do if statToggles[stat] then anyEnabled=true end end
    if not anyEnabled then
        StLbl.Text="⚠ Stat aç! (● yap)"; StLbl.TextColor3=Color3.fromRGB(255,185,40); return end
    for _,stat in ipairs(STATS) do
        if statToggles[stat] then
            local anyGrade=false
            for _,v in pairs(statAccepted[stat]) do if v then anyGrade=true; break end end
            if not anyGrade then
                StLbl.Text="⚠ "..STAT_SHORT[stat].." grade seç!"
                StLbl.TextColor3=Color3.fromRGB(255,185,40); return
            end
        end
    end

    isRunning=true
    SBtn.Text="⏹  Durdur"; SBtn.BackgroundColor3=Color3.fromRGB(165,32,32)
    StLbl.TextColor3=Color3.fromRGB(115,250,145)

    task.spawn(function()
        local rolls=0
        local allDone=false

        while isRunning and not allDone do
            allDone=true

            for _,stat in ipairs(STATS) do
                if not isRunning then break end
                if statToggles[stat] then
                    local accepted=isAccepted(stat)
                    dbg(stat.." accepted="..tostring(accepted))

                    if not accepted then
                        allDone=false
                        -- Fire remote
                        dbg("FireServer: "..selectedUnit.." | "..stat)
                        Remote:FireServer(selectedUnit,"Reroll",stat)
                        rolls=rolls+1

                        -- Countdown bekle (animasyon bitsin)
                        local prefix="🎲 "..STAT_SHORT[stat].." roll #"..rolls
                        waitWithCountdown(WAIT_AFTER_ROLL, prefix)
                        if not isRunning then break end

                        -- Şimdi oku
                        local newGrade=getGrade(stat)
                        local ok=newGrade and statAccepted[stat][newGrade]==true
                        dbg(stat.." sonuç: "..tostring(newGrade).." ok="..tostring(ok))

                        -- Kısa durum göster
                        local parts={}
                        for _,s in ipairs(STATS) do
                            if statToggles[s] then
                                local g=getGrade(s) or "?"
                                local check=statAccepted[s][g] and "✔" or "✘"
                                table.insert(parts, check..STAT_SHORT[s]..":"..g)
                            end
                        end
                        StLbl.Text=table.concat(parts," ")
                        StLbl.TextColor3=Color3.fromRGB(200,200,255)
                    end
                end
            end
        end

        if isRunning then
            -- Tüm statlar tamam
            isRunning=false
            SBtn.Text="▶  Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(72,38,188)
            local parts={}
            for _,stat in ipairs(STATS) do
                if statToggles[stat] then
                    table.insert(parts, STAT_SHORT[stat]..":"..(getGrade(stat) or "?"))
                end
            end
            StLbl.Text="✅ Bitti! "..table.concat(parts," ").." ("..rolls.."r)"
            StLbl.TextColor3=Color3.fromRGB(85,250,145)
        end
    end)
end)
