-- LOGIC
local function getGrade(stat)
    local p=PGui:FindFirstChild("Talents")
    if not p then return nil end
    p=p:FindFirstChild("_Frame"); if not p then return nil end
    p=p:FindFirstChild("Usage"); if not p then return nil end
    p=p:FindFirstChild("BODY"); if not p then return nil end
    p=p:FindFirstChild("Grade"); if not p then return nil end
    p=p:FindFirstChild(stat); if not p then return nil end
    local nb=p:FindFirstChild("Numbers"); if not nb then return nil end
    local txt=(nb.ContentText~="" and nb.ContentText) or nb.Text or ""
    return gradeFromText(txt)
end

local function isAccepted(stat)
    local any=false
    for _,v in pairs(statAccepted[stat]) do if v then any=true break end end
    if not any then return false end
    local cur=getGrade(stat)
    return cur~=nil and statAccepted[stat][cur]==true
end

local function needsReroll()
    local anyE=false
    for _,stat in ipairs(STATS) do
        if statToggles[stat] then anyE=true
            if not isAccepted(stat) then return true end
        end
    end
    return not anyE
end

SBtn.MouseButton1Click:Connect(function()
    if isRunning then
        isRunning=false
        SBtn.Text="▶  Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(72,38,188)
        StLbl.Text="⏸ Durduruldu"; StLbl.TextColor3=Color3.fromRGB(210,85,85); return
    end
    if not selectedUnit then StLbl.Text="⚠ Ünite seç!"; StLbl.TextColor3=Color3.fromRGB(255,185,40); return end
    local anyE=false
    for _,v in pairs(statToggles) do if v then anyE=true break end end
    if not anyE then StLbl.Text="⚠ Stat aç!"; StLbl.TextColor3=Color3.fromRGB(255,185,40); return end
    for _,stat in ipairs(STATS) do
        if statToggles[stat] then
            local any=false
            for _,v in pairs(statAccepted[stat]) do if v then any=true break end end
            if not any then StLbl.Text="⚠ "..STAT_SHORT[stat].." grade seç!"; StLbl.TextColor3=Color3.fromRGB(255,185,40); return end
        end
    end

    isRunning=true
    SBtn.Text="⏹  Durdur"; SBtn.BackgroundColor3=Color3.fromRGB(165,32,32)
    StLbl.Text="🔄 Başlıyor..."; StLbl.TextColor3=Color3.fromRGB(115,250,145)

    task.spawn(function()
        local rolls=0
        while isRunning do
            if not needsReroll() then
                isRunning=false
                SBtn.Text="▶  Başlat"; SBtn.BackgroundColor3=Color3.fromRGB(72,38,188)
                StLbl.Text="✅ Bitti! ("..rolls.."r)"; StLbl.TextColor3=Color3.fromRGB(85,250,145); break
            end
            for _,stat in ipairs(STATS) do
                if statToggles[stat] and not isAccepted(stat) then
                    Remote:FireServer(selectedUnit,"Reroll",stat)
                    task.wait(0.2)
                end
            end
            rolls=rolls+1
            local parts={}
            for _,stat in ipairs(STATS) do
                if statToggles[stat] then
                    table.insert(parts,STAT_SHORT[stat]..":"..(getGrade(stat) or "?"))
                end
            end
            StLbl.Text="🔄#"..rolls.." "..table.concat(parts," ")
            task.wait(0.35)
        end
    end)
end)
