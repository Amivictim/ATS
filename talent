-- Mobile drag
local dragging,dragStart,startPos=false,nil,nil
local TitleH=38
local function inputBegan(input)
    local pos=input.Position
    local abs=MF.AbsolutePosition
    if pos.X>=abs.X and pos.X<=abs.X+MF.AbsoluteSize.X
    and pos.Y>=abs.Y and pos.Y<=abs.Y+TitleH then
        dragging=true; dragStart=pos; startPos=MF.Position
    end
end
local function inputChanged(input)
    if dragging and dragStart then
        local delta=input.Position-dragStart
        MF.Position=UDim2.new(
            startPos.X.Scale, startPos.X.Offset+delta.X,
            startPos.Y.Scale, startPos.Y.Offset+delta.Y)
    end
end
local function inputEnded() dragging=false end
UIS.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then inputBegan(i) end end)
UIS.InputChanged:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement then inputChanged(i) end end)
UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then inputEnded() end end)

