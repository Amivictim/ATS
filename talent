local function populateUnits()
    for _,c in ipairs(UList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    local iv=PGui:FindFirstChild("Units") and PGui.Units:FindFirstChild("_Frame")
        and PGui.Units._Frame:FindFirstChild("Usage")
        and PGui.Units._Frame.Usage:FindFirstChild("BODY")
        and PGui.Units._Frame.Usage.BODY:FindFirstChild("Useable")
        and PGui.Units._Frame.Usage.BODY.Useable:FindFirstChild("Interview")
    local units={}
    if iv then
        for _,c in ipairs(iv:GetChildren()) do
            if not c:IsA("UIGridLayout") and not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
                table.insert(units,c.Name)
            end
        end
        table.sort(units)
    end
    if #units==0 then
        local nb=Instance.new("TextButton",UList)
        nb.Size=UDim2.new(1,0,0,26); nb.BackgroundTransparency=1
        nb.Text="⚠ Units GUI açık değil!"; nb.TextColor3=Color3.fromRGB(255,70,70)
        nb.TextSize=10; nb.Font=Enum.Font.Gotham; nb.ZIndex=21
        UList.CanvasSize=UDim2.new(0,0,0,26); return
    end
    for i,uid in ipairs(units) do
        local dn=(uid:match("^(.-)%s*%-") or uid):gsub("^%s+",""):gsub("%s+$","")
        local b=Instance.new("TextButton",UList)
        b.Size=UDim2.new(1,0,0,26)
        b.BackgroundColor3=selectedUnit==uid and Color3.fromRGB(58,32,135) or Color3.fromRGB(24,20,42)
        b.BackgroundTransparency=selectedUnit==uid and 0 or 0.15
        b.Text="  "..dn; b.TextColor3=Color3.fromRGB(205,200,245)
        b.TextSize=11; b.Font=Enum.Font.Gotham
        b.TextXAlignment=Enum.TextXAlignment.Left; b.BorderSizePixel=0; b.LayoutOrder=i; b.ZIndex=21
        b.MouseButton1Click:Connect(function()
            selectedUnit=uid
            UBtn.Text="  ✔ "..dn.." ▾"; UBtn.TextColor3=Color3.fromRGB(115,250,145)
            unitOpen=false; UList.Visible=false; UList.Size=UDim2.new(0,W-12,0,0)
        end)
    end
    UList.CanvasSize=UDim2.new(0,0,0,#units*26)
end

UBtn.MouseButton1Click:Connect(function()
    unitOpen=not unitOpen
    if unitOpen then
        populateUnits(); positionUList()
        local n=math.max(1,#UList:GetChildren()-1)
        UList.Visible=true; UList.Size=UDim2.new(0,W-12,0,math.min(n*26,104))
    else
        UList.Visible=false
    end
end)

