-- ── GRADES ──────────────────────────────────────────────────────────────────
local GRADES = {"SSS+","SSS","SSS-","SS+","SS","SS-","S+","S","S-",
                "A+","A","A-","B+","B","B-","C+","C","C-","D+","D","D-","E+","E","E-"}

local function gradeFromText(raw)
    raw = tostring(raw):gsub("%s+","")
    for _,g in ipairs(GRADES) do if raw==g then return g end end
    for _,g in ipairs(GRADES) do if raw:sub(1,#g)==g then return g end end
    return nil
end

