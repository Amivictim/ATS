-- ── GRADE READER ─────────────────────────────────────────────────────────────
local function getNumbersLabel(stat)
    local root = PGui:FindFirstChild("Talents"); if not root then return nil end
    local p = root:FindFirstChild("_Frame"); if not p then return nil end
    p = p:FindFirstChild("Usage"); if not p then return nil end
    p = p:FindFirstChild("BODY"); if not p then return nil end
    p = p:FindFirstChild("Grade"); if not p then return nil end
    p = p:FindFirstChild(stat); if not p then return nil end
    return p:FindFirstChild("Numbers")
end

local function getGrade(stat)
    local nb = getNumbersLabel(stat); if not nb then return nil end
    local txt = (nb.ContentText ~= "" and nb.ContentText) or nb.Text or ""
    local g = gradeFromText(txt)
    dbg(stat.." raw='"..txt.."' => "..tostring(g))
    return g
end

-- ── INVENTORY HIGHLIGHT ───────────────────────────────────────────────────────
local highlightStroke = nil
local function clearHighlight()
    if highlightStroke and highlightStroke.Parent then highlightStroke:Destroy() end
    highlightStroke = nil
end
local function applyHighlight(frame)
    clearHighlight()
    if not frame then return end
    local s = Instance.new("UIStroke", frame)
    s.Color = Color3.fromRGB(100,255,120); s.Thickness = 3
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    highlightStroke = s
end

