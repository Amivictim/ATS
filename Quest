local function isMobAlive(model)
    if not model or not model.Parent then return false end
    local h = model:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

local function findMob(name)
    local s = workspace:FindFirstChild("Worlds")
    if not s then return nil end
    s = s:FindFirstChild("Targets")
    if not s then return nil end
    s = s:FindFirstChild("Server")
    if not s then return nil end
    for _, model in ipairs(s:GetChildren()) do
        local ud = model:FindFirstChild("Units_Displays")
        if ud then
            local n = ud:FindFirstChild("Names")
            local h = model:FindFirstChildOfClass("Humanoid")
            if n and h and h.Health > 0 and n.Text:find(name, 1, true) then
                return model
            end
        end
    end
    return nil
end

local function getQuests()
    local quests = {}
    local ok, list = pcall(function()
        return LP.PlayerGui:WaitForChild("HUD")
            :WaitForChild("RightSide")
            :WaitForChild("Quest")
            :WaitForChild("List")
    end)
    if not ok or not list then return quests end
    for _, child in ipairs(list:GetChildren()) do
        if child:IsA("Frame") then
            local names = child:FindFirstChild("Names")
            if names and names.Text ~= "" then
                local cur, tot, mob = names.Text:match("%((%d+)%/(%d+)%)%s*Defeat%s*%d+%s*(.+)")
                if mob and tonumber(cur) and tonumber(tot) and tonumber(cur) < tonumber(tot) then
                    table.insert(quests, mob:match("^%s*(.-)%s*$"))
                end
            end
        end
    end
    return quests
end

local function teleportToMob(model)
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local mobRoot = model:FindFirstChild("HumanoidRootPart")
    if not root or not mobRoot then return end
    root.CFrame = mobRoot.CFrame * CFrame.new(4, 0, 4)
end

