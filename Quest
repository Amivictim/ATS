local function startLoop()
    while running do
        local quests = getQuests()

        if #quests == 0 then
            statusLabel.Text = "Status: No Quests"
            targetLabel.Text = "Target: —"
            task.wait(2)
            continue
        end

        for _, mobName in ipairs(quests) do
            if not running then break end

            statusLabel.Text = "Status: Hunting"
            targetLabel.Text = "Target: " .. mobName

            local mob = findMob(mobName)
            if mob and isMobAlive(mob) then
                teleportToMob(mob)
                task.wait(0.3)
                pcall(function()
                    Remote:FireServer(mob.Name, "Mouse")
                end)

                while isMobAlive(mob) and running do
                    teleportToMob(mob)
                    pcall(function()
                        Remote:FireServer(mob.Name, "Mouse")
                    end)
                    task.wait(3)
                end
            else
                task.wait(1)
            end
        end

        task.wait(0.5)
    end
end

